{
  "ConnectionStrings": {
    // Local PostgreSQL. Password is omitted because Postgres.app uses trust auth for local connections.
    "DefaultConnection": "Host=localhost;Port=5432;Database=basarsoft_internship;Username=cobanmonur"
  },
  "Jwt": {
    // Issuer/Audience identify who minted the token and who it is for.
    "Issuer": "Basarsoft.Api",
    "Audience": "basarsoft-client",
    // The HS256 signing key is deliberately NOT here: a committed key would let anyone with repo
    // access mint valid tokens. Development reads it from appsettings.Development.json; any other
    // environment must supply it via user-secrets or the Jwt__Key environment variable
    // (startup fails fast when it is missing).
    // Token lifetime in minutes
    "ExpiresMinutes": 10
  },
  "Cors": {
    // Origins allowed to call this API from a browser. Add the deployed client's origin here
    // (or in an environment-specific config); the dev default is the local Vite server.
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "GeoServer": {
    // Local GeoServer that publishes the PostGIS geometry as WFS/WMS. The map's read now flows
    // React -> this API -> GeoServer -> PostGIS. Workspace holds the per-user vw_point/line/polygon views.
    "BaseUrl": "http://localhost:8080/geoserver",
    "Workspace": "basarsoft"
  },
  "Routing": {
    "PrimaryBaseUrl": "http://localhost:5001",
    "FallbackBaseUrl": "",
    "Profile": "driving",
    "TimeoutSeconds": 10
  },
  "RouteSimulation": {
    "UpdateIntervalMilliseconds": 1000,
    "TimeScale": 60,
    "FallbackSpeedMetersPerSecond": 13.89
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
