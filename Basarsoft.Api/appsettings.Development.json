{
  "Jwt": {
    // Development-only HS256 signing key (>= 32 chars). Fine to commit BECAUSE this file only
    // loads in the Development environment; production must set Jwt__Key via user-secrets/env,
    // and Program.cs refuses to start with a missing or known-burned key.
    "Key": "basarsoftgis-local-dev-signing-key-2026-not-for-prod!"
  },
  "Routing": {
    // Development-only safety net for the local Docker OSRM on :5001. OsrmRoutingService only tries
    // this after a *transient* primary failure (connection refused, timeout, or 5xx), so route builds
    // keep working while the Turkey graph is still being preprocessed — or if the container is down.
    // Deliberately NOT set in appsettings.json: the committed default must stay disabled, because a
    // fallback sends stop coordinates to a third-party host.
    // http, not https, on purpose. The demo server's TLS handshake fails against .NET's macOS
    // AppleCrypto stack ("Interop+AppleCrypto+SslException: handshake failure") even though curl
    // negotiates it fine, and the host serves the same API over plain HTTP without redirecting.
    "FallbackBaseUrl": "http://router.project-osrm.org"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
